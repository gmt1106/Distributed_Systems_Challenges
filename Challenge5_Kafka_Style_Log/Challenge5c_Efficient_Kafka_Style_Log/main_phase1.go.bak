package main

import (
	"context"
	"encoding/json"
	"fmt"
	"log"

	maelstrom "github.com/jepsen-io/maelstrom/demo/go"
)

type entry struct {
	Offset int
	Msg    int
}


func main() {
	n := maelstrom.NewNode()
	kv := maelstrom.NewLinKV(n)
	ctx := context.Background()

	n.Handle("send", func(msg maelstrom.Message) error {

		var body struct {
			Type    string  `json:"type"`
			Key     string  `json:"key"`
			Msg     int     `json:"msg"`
		}

		if err := json.Unmarshal(msg.Body, &body); err != nil {
			return err
		}

		offsetKey := fmt.Sprintf("offset_%s", body.Key)
		foundCurOffset := 0

		for {
			// try to get offset by key
			curOffset, offsetErr := kv.ReadInt(ctx, offsetKey)
			// key does not exist yet, set to 0
			if offsetErr != nil {
				curOffset = 0
			}
			// increment offset by one
			offsetErr = kv.CompareAndSwap(ctx, offsetKey, curOffset, curOffset + 1, true)
			// offset is not incremented. Get a new one
			if offsetErr != nil {
				continue
			}

			// offset is found!
			foundCurOffset = curOffset

			break;
		}

		// create message key
		msgKey := fmt.Sprintf("msg_%s_%d", body.Key, foundCurOffset)

		// write the log
		kv.Write(ctx, msgKey, body.Msg)


		return n.Reply(msg, map[string]any{
			"type": "send_ok",
			"offset": foundCurOffset,
		})
	})

	n.Handle("poll", func(msg maelstrom.Message) error {

		var body struct {
			Type        string          `json:"type"`
			Offsets     map[string]int  `json:"offsets"`
		}

		if err := json.Unmarshal(msg.Body, &body); err != nil {
			return err
		}

		responseMap := make(map[string]any)
		responseMap["type"] = "poll_ok"
		
		msgs := map[string][][2]int{}


		for key, offset := range body.Offsets {

			nextOffset := offset

			// try to get message with next offset until not found
			for {
				
				// create message key
				msgKey := fmt.Sprintf("msg_%s_%d", key, nextOffset)

				// read next message
				val, err := kv.ReadInt(ctx, msgKey)

				// message with this key does not exist
				if err != nil {
					break
				}

				msgs[key] = append(msgs[key], [2]int{nextOffset, val})
				nextOffset++
			}
		}

		responseMap["msgs"] = msgs

		return n.Reply(msg, responseMap)

	})

	n.Handle("commit_offsets", func(msg maelstrom.Message) error {

		var body struct {
			Type        string          `json:"type"`
			Offsets     map[string]int  `json:"offsets"`
		}

		if err := json.Unmarshal(msg.Body, &body); err != nil {
			return err
		}

		for key, offset := range body.Offsets {

			committedKey := fmt.Sprintf("committed_%s", key)

			committed, committedErr := kv.Read(ctx, committedKey)

			if committedErr != nil {
				committed = 0
			}

			if offset > committed.(int) {
				kv.Write(ctx, committedKey, offset)
			}
		}

		return n.Reply(msg, map[string]any{
			"type": "commit_offsets_ok",
		})

	})

	n.Handle("list_committed_offsets", func(msg maelstrom.Message) error {

		var body struct {
			Type     string      `json:"type"`
			Keys     []string    `json:"keys"`
		}

		if err := json.Unmarshal(msg.Body, &body); err != nil {
			return err
		}

		responseMap := make(map[string]any)
		responseMap["type"] = "list_committed_offsets_ok"

		filteredCommittedOffset := make(map[string]int)

		for _, key := range body.Keys {

			committedKey := fmt.Sprintf("committed_%s", key)

			committed, committedErr := kv.Read(ctx, committedKey)
			
			if committedErr != nil {
				committed = 0
			}

			filteredCommittedOffset[key] = committed.(int);
		}
		
		responseMap["offsets"] = filteredCommittedOffset;

		return n.Reply(msg, responseMap)

	})

	if err := n.Run(); err != nil {
		log.Fatal(err)
	}

}
